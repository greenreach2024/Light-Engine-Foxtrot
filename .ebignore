# Elastic Beanstalk ignore file
# Don't upload these to Beanstalk

# Python virtual environment
venv/
.venv/
__pycache__/
*.pyc

# Node modules (will be installed on server)
node_modules/

# Development files
.git/
.github/
.vscode/
*.log
npm-debug.log*
.elasticbeanstalk/

# Documentation
*.md
!README.md

# Test files
test/
tests/
*.test.js

# Mobile app
mobile-app/

# Large deployment files
*.zip
external/
venv/
firmware/
logs/
*.log
desktop-app/
backups/
dist/
docs/
frontend/
hq-app/
edge-app/
esp32/
esp32-firmware/
examples/
/data/
data.aws-backup/
lib.aws-backup/
server.aws-backup/
greenreach-central/

# Large media files
*.mov
*.mp4
*.avi
*.har
public/videos/
public/images/*.jpeg
public/images/plant-farm/

# Database files (if any)
*.db
*.sqlite
*.elf
*.map
*.a

# Environment files
.env.local
.env.development

# OS files
.DS_Store
Thumbs.db

# Build artifacts
*.bundle.js

# Scripts and tools not needed in production
*.sh
*.py
!scripts/simple-anomaly-detector.py

# Preserve EB platform hooks (MUST come AFTER *.sh exclusion to override it)
!.platform/
!.platform/**
alembic.ini
alembic/
create-*.js
check-*.js
cleanup-*.sh
build-and-verify.sh
