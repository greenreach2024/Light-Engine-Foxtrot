# Elastic Beanstalk ignore file
# Don't upload these to Beanstalk

# Python virtual environment
venv/
.venv/
__pycache__/
*.pyc

# Node modules (will be installed on server)
node_modules/

# Development files
.git/
.github/
.vscode/
*.log
npm-debug.log*
.elasticbeanstalk/

# Documentation
*.md
!README.md

# Test files
test/
tests/
*.test.js

# Mobile app (archived)
# mobile-app/ -- moved to archive/legacy/

# Large deployment files
*.zip
external/
config/sync-queue.json
data/sync-monitor-snapshot.json
venv/
logs/
*.log
backups/
docs/
examples/
/data/
data.aws-backup/
lib.aws-backup/
server.aws-backup/

# Archived legacy code (esp32, firmware, mobile-app, etc.)
archive/
# greenreach-central/ — selectively include code dirs for Faye
greenreach-central/node_modules/
greenreach-central/public/
greenreach-central/data/
greenreach-central/docs/
greenreach-central/scripts/
greenreach-central/backups/
greenreach-central/tests/
greenreach-central/migrations/
greenreach-central/reports/
greenreach-central/server.js
greenreach-central/server.js.*
greenreach-central/package*.json
greenreach-central/*.md
greenreach-central/*.txt
greenreach-central/*.mjs
greenreach-central/*.bak

# Large media files
*.mov
*.mp4
*.avi
*.har
public/videos/
public/images/*.jpeg
public/images/plant-farm/

# Database files (if any)
*.db
*.sqlite
*.elf
*.map
*.a

# Environment files
.env.local
.env.development

# OS files
.DS_Store
Thumbs.db

# Build artifacts
*.bundle.js

# Scripts and tools not needed in production
*.sh
*.py
!scripts/simple-anomaly-detector.py

# Preserve EB platform hooks (MUST come AFTER *.sh exclusion to override it)
!.platform/
!.platform/**
light-engine-access-manager/
