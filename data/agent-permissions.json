{
  "_version": "1.0.0",
  "_description": "Agent permission matrix — defines per-agent-class action scopes and human-approval tiers. Loaded by services/ai-agent.js to gate actions at runtime.",
  "_tiers": {
    "auto": "Action executes immediately without human confirmation",
    "recommend": "Agent generates recommendation; human reviews and clicks to apply",
    "require-approval": "Action queued for explicit human approval before execution"
  },

