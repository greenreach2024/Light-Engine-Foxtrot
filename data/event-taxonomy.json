{
  "$schema": "event-taxonomy-v1",
  "version": "1.2.0",
  "description": "Canonical event names and schemas for Light Engine Foxtrot. All system events should emit payloads conforming to these definitions.",
  "events": {
    "seed": {
      "name": "seed",
      "category": "grow",
      "description": "Seeds planted into a tray or grow site",
      "emitted_by": [
        "server-foxtrot.js:POST /api/tray-runs"
      ],
      "payload": {
        "event_type": "seed",
        "tray_run_id": "string",
        "group_id": "string|null",
        "crop": "string",
        "variety": "string|null",
        "seed_count": "number",
        "tray_format": "string|null",
        "zone": "string|null",
        "room": "string|null",
        "recipe_id": "string|null",
        "seeded_by": "string|null",
        "timestamp": "ISO8601"
      },
      "status": "active"
    },
    "transplant": {
      "name": "transplant",
      "category": "grow",
      "description": "Plants moved from one tray/zone to another",
      "emitted_by": [],
      "payload": {
        "event_type": "transplant",
        "tray_run_id": "string",
        "from_zone": "string",
        "to_zone": "string",
        "plant_count": "number",
        "crop": "string",
        "transplanted_by": "string|null",
        "timestamp": "ISO8601"
      },
      "status": "planned"
    },
    "harvest": {
      "name": "harvest",
      "category": "grow",
      "description": "Crop harvested from a tray or grow site",
      "emitted_by": [
        "server-foxtrot.js:POST /api/harvest",
        "server-foxtrot.js:POST /api/tray-runs/:id/harvest"
      ],
      "payload": {
        "event_type": "harvest",
        "tray_run_id": "string|null",
        "group_id": "string|null",
        "crop": "string",
        "total_weight_oz": "number",
        "harvested_count": "number",
        "planted_count": "number",
        "loss_count": "number",
        "grow_days": "number",
        "quality_grade": "string|null",
        "experiment_id": "string|null",
        "zone": "string|null",
        "room": "string|null",
        "harvested_by": "string|null",
        "timestamp": "ISO8601"
      },
      "status": "active"
    },
    "loss": {
      "name": "loss",
      "category": "grow",
      "description": "Plant loss recorded (disease, mechanical, environmental, etc.)",
      "emitted_by": [
        "server-foxtrot.js:POST /api/tray-runs/:id/loss"
      ],
      "payload": {
        "event_type": "loss",
        "tray_run_id": "string",
        "group_id": "string|null",
        "crop": "string",
        "loss_count": "number",
        "loss_reason": "string",
        "loss_category": "disease|mechanical|environmental|pest|other",
        "zone": "string|null",
        "reported_by": "string|null",
        "timestamp": "ISO8601"
      },
      "status": "active"
    },
    "order": {
      "name": "order",
      "category": "commerce",
      "description": "Wholesale or retail order placed by a buyer",
      "emitted_by": [
        "server-foxtrot.js:POST /api/wholesale/webhook/order"
      ],
      "payload": {
        "event_type": "order",
        "order_id": "string",
        "buyer_id": "string",
        "items": "array",
        "total_amount": "number",
        "currency": "string",
        "status": "string",
        "timestamp": "ISO8601"
      },
      "status": "planned"
    },
    "delivery": {
      "name": "delivery",
      "category": "commerce",
      "description": "Order delivered or picked up by buyer",
      "emitted_by": [],
      "payload": {
        "event_type": "delivery",
        "order_id": "string",
        "delivery_method": "pickup|delivery",
        "delivered_at": "ISO8601",
        "signed_by": "string|null",
        "timestamp": "ISO8601"
      },
      "status": "planned"
    },
    "payout": {
      "name": "payout",
      "category": "finance",
      "description": "Payment settled for a completed order",
      "emitted_by": [],
      "payload": {
        "event_type": "payout",
        "order_id": "string",
        "amount": "number",
        "currency": "string",
        "method": "string",
        "reference": "string|null",
        "timestamp": "ISO8601"
      },
      "status": "planned"
    },
    "quality_check": {
      "name": "quality_check",
      "category": "quality",
      "description": "Quality control inspection of harvested product",
      "emitted_by": [],
      "payload": {
        "event_type": "quality_check",
        "lot_code": "string",
        "crop": "string",
        "grade": "A|B|C|reject",
        "inspector": "string|null",
        "notes": "string|null",
        "timestamp": "ISO8601"
      },
      "status": "planned"
    },
    "agent_action": {
      "name": "agent_action",
      "category": "ai",
      "description": "AI agent generated a recommendation or took an autonomous action",
      "emitted_by": [
        "services/ai-agent.js"
      ],
      "payload": {
        "event_type": "agent_action",
        "agent_class": "string",
        "action_type": "recommendation|autonomous|escalation",
        "input_summary": "string",
        "recommendation": "string",
        "human_decision": "accepted|rejected|pending|null",
        "confidence": "number|null",
        "timestamp": "ISO8601"
      },
      "status": "planned"
    },
    "lead_created": {
      "name": "lead_created",
      "category": "commerce",
      "description": "New purchase lead / interest form submitted (visitor \u2192 lead conversion)",
      "emitted_by": [
        "routes/purchase-leads.js:POST /api/purchase/leads"
      ],
      "payload": {
        "event_type": "lead_created",
        "lead_id": "string",
        "farm_name": "string",
        "email": "string",
        "plan": "string|null",
        "source": "string",
        "timestamp": "ISO8601"
      },
      "status": "active"
    },
    "lead_status_changed": {
      "name": "lead_status_changed",
      "category": "commerce",
      "description": "Lead funnel stage changed (e.g. new \u2192 contacted \u2192 scheduled \u2192 converted)",
      "emitted_by": [
        "routes/purchase-leads.js:PUT /api/purchase/leads/:id/status"
      ],
      "payload": {
        "event_type": "lead_status_changed",
        "lead_id": "string",
        "previous_status": "string",
        "new_status": "string",
        "farm_name": "string|null",
        "timestamp": "ISO8601"
      },
      "status": "active"
    },
    "demand_signal_refresh": {
      "name": "demand_signal_refresh",
      "category": "ai",
      "description": "Demand signals received from GreenReach Central. Triggers automatic succession plan generation.",
      "emitted_by": [
        "server-foxtrot.js:POST /api/ai/recommendations/receive"
      ],
      "payload": {
        "event_type": "demand_signal_refresh",
        "demand_signals": "object",
        "source": "string",
        "timestamp": "ISO8601"
      },
      "status": "active"
    },
    "partial_harvest": {
      "name": "partial_harvest",
      "category": "grow",
      "description": "Partial harvest (cut) from a CCA (cut-and-come-again) crop. Tray remains active for regrowth.",
      "emitted_by": [
        "server-foxtrot.js:POST /api/tray-runs/:id/harvest"
      ],
      "payload": {
        "event_type": "partial_harvest",
        "tray_run_id": "string",
        "group_id": "string|null",
        "crop": "string",
        "cut_number": "number",
        "remaining_cuts": "number",
        "max_cuts": "number",
        "next_expected_cut_date": "ISO8601|null",
        "total_weight_oz": "number|null",
        "harvested_count": "number|null",
        "planted_count": "number|null",
        "grow_days": "number",
        "regrowth_days": "number",
        "yield_factor": "number",
        "quality_grade": "string|null",
        "experiment_id": "string|null",
        "zone": "string|null",
        "room": "string|null",
        "harvested_by": "string|null",
        "timestamp": "ISO8601"
      },
      "status": "active"
    },
    "agent_decision": {
      "name": "agent_decision",
      "category": "ai",
      "description": "An AI agent recorded a decision with inputs, alternatives, and chosen action",
      "emitted_by": [
        "lib/decision-ledger.js"
      ],
      "payload": {
        "event_type": "agent_decision",
        "agent": "string",
        "decision_type": "string",
        "inputs": "object|null",
        "alternatives": "array",
        "chosen": "object",
        "approval": "string",
        "outcome": "object|null",
        "farm_id": "string|null",
        "timestamp": "ISO8601"
      },
      "status": "active"
    }
  },
  "categories": {
    "grow": "Seed-to-harvest lifecycle events",
    "commerce": "Orders, deliveries, buyer interactions, and marketing funnel",
    "finance": "Payments, payouts, and settlements",
    "quality": "Quality control and inspection",
    "ai": "AI agent actions and recommendations"
  }
}
