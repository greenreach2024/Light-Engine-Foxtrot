{
  "name": "light-engine-foxtrot",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Light Engine Foxtrot single-server app",
  "main": "server-foxtrot.js",
  "scripts": {
    "start": "node server-foxtrot.js",
    "start:pm2": "pm2 start ecosystem.config.cjs && pm2 status",
    "start:local": "PORT=8091 node server-charlie.js",
    "start:cloud": "ENV_SOURCE=cloud node server-charlie.js",
    "smoke": "node scripts/smoke.js",
    "test": "node --test --test-timeout=10000 \"tests/**/*.mjs\"",
    "nutrient:setpoints": "node scripts/nutrient-push-setpoints.js",
    "mock:heatmap": "node scripts/generate-mock-heatmap-data.cjs",
    "setup:notifications": "node scripts/setup-notifications.js",
    "test:notifications": "node scripts/test-notifications.js",
    "test:overselling": "node scripts/test-overselling-prevention.js",
    "test:alerts": "node scripts/test-alert-system.js",
    "test:e2e": "node scripts/test-end-to-end-order.js",
    "cleanup:reservations": "node scripts/cleanup-expired-reservations.js",
    "reports:weekly": "node scripts/send-weekly-reports.js",
    "build:edge": "webpack --config webpack.edge.config.cjs",
    "build:edge:analyze": "webpack --config webpack.edge.config.cjs --profile --json > dist/stats.json",
    "build:pkg": "node scripts/build-binaries.js",
    "build:pkg:test": "node scripts/test-binary.js"
  },
  "dependencies": {
    "@aws-sdk/client-cloudwatch": "^3.956.0",
    "@aws-sdk/client-secrets-manager": "^3.956.0",
    "bonjour-service": "^1.3.0",
    "canvas": "^3.2.0",
    "dotenv": "^17.2.3",
    "express": "^4.19.2",
    "express-validator": "^7.3.1",
    "express-ws": "^5.0.2",
    "firebase-admin": "^13.6.0",
    "helmet": "^8.1.0",
    "http-proxy-middleware": "^2.0.6",
    "jsbarcode": "^3.12.1",
    "jsonwebtoken": "^9.0.3",
    "mqtt": "^5.3.4",
    "nedb-promises": "^6.2.3",
    "node-quickbooks": "^2.0.47",
    "nodemailer": "^7.0.12",
    "pdf-lib": "^1.17.1",
    "pg": "^8.16.3",
    "qrcode": "^1.5.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "square": "^37.1.1",
    "tplink-smarthome-api": "^5.0.0",
    "twilio": "^5.11.1"
  },
  "keywords": [
    "lighting",
    "control",
    "automation"
  ],
  "author": "Peter Gilbert",
  "license": "MIT",
  "devDependencies": {
    "@babel/core": "^7.28.5",
    "@babel/preset-env": "^7.28.5",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "babel-loader": "^10.0.0",
    "javascript-obfuscator": "^5.1.0",
    "pkg": "^5.8.1",
    "terser-webpack-plugin": "^5.3.16",
    "webpack": "^5.104.1",
    "webpack-cli": "^6.0.1",
    "webpack-obfuscator": "^3.6.0"
  }
}
