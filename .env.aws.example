# ==========================================
# AWS Configuration for Light Engine
# ==========================================

# AWS Account & Region
AWS_ACCOUNT_ID=
AWS_REGION=us-east-1
AWS_DEFAULT_REGION=us-east-1

# AWS Access Credentials
# IMPORTANT: Never commit these to version control!
# Use AWS IAM user with minimal required permissions
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Optional: AWS Session Token (for temporary credentials)
AWS_SESSION_TOKEN=

# ==========================================
# S3 Storage Configuration
# ==========================================

# Primary S3 Bucket for Application Data
AWS_S3_BUCKET=light-engine-data-production
AWS_S3_BUCKET_REGION=us-east-1

# S3 Bucket for Static Assets (if separate)
AWS_S3_ASSETS_BUCKET=light-engine-assets-production

# S3 Bucket for Backups
AWS_S3_BACKUP_BUCKET=light-engine-backups

# S3 Access Control
AWS_S3_PUBLIC_ACCESS=false
AWS_S3_ENCRYPTION=AES256

# S3 Path Prefixes
AWS_S3_PREFIX_TENANT_DATA=tenants/
AWS_S3_PREFIX_TELEMETRY=telemetry/
AWS_S3_PREFIX_LOGS=logs/
AWS_S3_PREFIX_EXPORTS=exports/
AWS_S3_PREFIX_INVOICES=invoices/

# ==========================================
# CloudFront CDN Configuration
# ==========================================

# CloudFront Distribution ID
AWS_CLOUDFRONT_DISTRIBUTION_ID=E2N3IO26J80JEK
AWS_CLOUDFRONT_DOMAIN=

# CloudFront Invalidation Settings
AWS_CLOUDFRONT_INVALIDATE_ON_DEPLOY=true
AWS_CLOUDFRONT_INVALIDATION_PATHS=/index.html,/billing.html,/admin.html,/manifest.json

# ==========================================
# AWS Lambda Configuration (if used)
# ==========================================

# Lambda Function Names
AWS_LAMBDA_ENV_AGGREGATOR=light-engine-env-aggregator
AWS_LAMBDA_WEBHOOK_HANDLER=light-engine-webhook-handler
AWS_LAMBDA_USAGE_TRACKER=light-engine-usage-tracker

# Lambda Runtime
AWS_LAMBDA_RUNTIME=python3.9
AWS_LAMBDA_MEMORY=512
AWS_LAMBDA_TIMEOUT=30

# ==========================================
# DynamoDB Configuration (if used)
# ==========================================

# DynamoDB Table Names
AWS_DYNAMODB_TENANTS_TABLE=light-engine-tenants
AWS_DYNAMODB_SUBSCRIPTIONS_TABLE=light-engine-subscriptions
AWS_DYNAMODB_USAGE_TABLE=light-engine-usage
AWS_DYNAMODB_TELEMETRY_TABLE=light-engine-telemetry

# DynamoDB Settings
AWS_DYNAMODB_READ_CAPACITY=5
AWS_DYNAMODB_WRITE_CAPACITY=5
AWS_DYNAMODB_BILLING_MODE=PAY_PER_REQUEST

# ==========================================
# SQS Queue Configuration (if used)
# ==========================================

# SQS Queue URLs
AWS_SQS_WEBHOOK_QUEUE=https://sqs.us-east-1.amazonaws.com/ACCOUNT_ID/light-engine-webhooks
AWS_SQS_TELEMETRY_QUEUE=https://sqs.us-east-1.amazonaws.com/ACCOUNT_ID/light-engine-telemetry
AWS_SQS_NOTIFICATIONS_QUEUE=https://sqs.us-east-1.amazonaws.com/ACCOUNT_ID/light-engine-notifications

# ==========================================
# SNS Topic Configuration (if used)
# ==========================================

# SNS Topic ARNs
AWS_SNS_ALERTS_TOPIC=arn:aws:sns:us-east-1:ACCOUNT_ID:light-engine-alerts
AWS_SNS_BILLING_TOPIC=arn:aws:sns:us-east-1:ACCOUNT_ID:light-engine-billing

# ==========================================
# CloudWatch Configuration
# ==========================================

# CloudWatch Log Groups
AWS_CLOUDWATCH_LOG_GROUP=/light-engine/production
AWS_CLOUDWATCH_LOG_RETENTION_DAYS=30

# CloudWatch Alarms
AWS_CLOUDWATCH_ALARMS_ENABLED=true
AWS_CLOUDWATCH_ALARM_EMAIL=ops@greenreach.farm

# ==========================================
# Route 53 DNS Configuration (if used)
# ==========================================

# Route 53 Hosted Zone
AWS_ROUTE53_ZONE_ID=
AWS_ROUTE53_DOMAIN=lightengine.io

# ==========================================
# ACM SSL Certificate
# ==========================================

# ACM Certificate ARN
AWS_ACM_CERTIFICATE_ARN=arn:aws:acm:us-east-1:ACCOUNT_ID:certificate/CERT_ID

# ==========================================
# IAM Role ARNs
# ==========================================

# IAM Roles for Services
AWS_IAM_ROLE_LAMBDA_EXECUTION=arn:aws:iam::ACCOUNT_ID:role/light-engine-lambda-execution
AWS_IAM_ROLE_EC2_INSTANCE=arn:aws:iam::ACCOUNT_ID:role/light-engine-ec2-instance
AWS_IAM_ROLE_ECS_TASK=arn:aws:iam::ACCOUNT_ID:role/light-engine-ecs-task

# ==========================================
# Cost Management
# ==========================================

# Budget & Billing Alerts
AWS_BUDGET_LIMIT_MONTHLY=500
AWS_BILLING_ALERT_THRESHOLD=80
AWS_COST_ALLOCATION_TAGS=Environment,Project,Tenant

# ==========================================
# Tags (for resource organization)
# ==========================================

AWS_TAG_ENVIRONMENT=production
AWS_TAG_PROJECT=light-engine
AWS_TAG_OWNER=greenreach
AWS_TAG_COST_CENTER=engineering

# ==========================================
# Reference: Existing Real Estate Reach Setup
# ==========================================

# Real Estate Reach Web Production (for reference)
# AWS_S3_BUCKET=realestate-reach-web-production
# AWS_CLOUDFRONT_DISTRIBUTION_ID=E2N3IO26J80JEK
# AWS_REGION=us-east-1  # (verify with aws s3api get-bucket-location)
