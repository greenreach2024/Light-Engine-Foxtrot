# Environment Configuration
# Copy this file to .env and fill in your values

# Server
PORT=3100
NODE_ENV=production

# Database
DATABASE_URL=postgresql://localhost:5432/greenreach_central

# Authentication
# Generate a secure random token:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_TOKEN=change-this-to-secure-random-token-in-production

# Optional: CORS (comma-separated)
# ALLOWED_ORIGINS=https://central.greenreach.io,https://admin.greenreach.io

# Optional: Logging
# LOG_LEVEL=info
