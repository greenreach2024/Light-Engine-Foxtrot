# Central .dockerignore - keep image small
.git
.github/*
!.github/*.md
!.github/skills/
.vscode
.elasticbeanstalk
node_modules
venv
__pycache__

# Test and dev
tests/
*.test.js
*.md
!README.md
!faye-security-workbook.md
!FAYE_VISION.md
!EVIE_VISION.md

# Docs and scripts
docs/
scripts/
# reports/ - needed by server.js import
backups/
migrations/

# Large media
public/videos/

# Logs
logs/
*.log

# Secrets (passed via Cloud Run env vars / Secret Manager)
.env
.env.*
*.pem
*.key
*.crt

# OS
.DS_Store
Thumbs.db

# Dockerfile itself
Dockerfile

# Per-farm demo/state JSONs -- MUST NOT ship in image.
# These are the logical data types backed by farmStore (see lib/farm-data-store.js
# TYPE_TO_FILE). Shipping them leaks image-baked demo data to unauthenticated
# callers and causes the 78-ZipGrow-Standard overwrite bug (cdefb512, a2cd5454).
# Catalogs/templates (equipment.catalog.json, spd-library.json, crop-registry.json,
# farm-api-keys.json, etc.) are deliberately NOT listed here and continue to ship.
# groups.json and rooms.json ship as empty stubs (harmless with
# farmStore read-fallback disabled in a2cd5454). Keeps parity with LE
# and avoids any legacy reader tripping on ENOENT.
public/data/room-map.json
public/data/farm.json
public/data/farm-settings.json
public/data/iot-devices.json
public/data/env.json
public/data/env-cache.json
public/data/plans.json
public/data/inventory.json
public/data/schedules.json
public/data/configuration.json
public/data/dedicated-crops.json
public/data/procurement-orders.json
public/data/nutrient-dashboard.json
public/data/demo-farm-data.json
public/data/planting-schedule.json
public/data/harvest-log.json
public/data/system-alerts.json
public/data/ai-recommendations.json
public/data/devices.cache.json
public/data/wholesale-orders-status.json
public/data/wholesale-order-events.json
public/data/wholesale-reservations.json
public/data/demand-succession-suggestions.json
