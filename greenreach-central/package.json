{
  "name": "greenreach-central-api",
  "version": "1.0.0",
  "description": "GreenReach Central API - Multi-farm management and monitoring platform",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "NODE_ENV=development nodemon server.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "db:migrate": "node scripts/migrate.js",
    "db:seed": "node scripts/seed.js",
    "smoke:farm-contract": "bash scripts/test-farm-contract-endpoints.sh",
    "deploy:prod:gated": "bash scripts/deploy-prod-with-contract-gate.sh"
  },
  "keywords": [
    "agriculture",
    "indoor-farming",
    "farm-management",
    "multi-tenant",
    "api"
  ],
  "author": "GreenReach Farms",
  "license": "PROPRIETARY",
  "dependencies": {
    "axios": "^1.6.5",
    "bcryptjs": "^2.4.3",
    "cheerio": "^1.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "openai": "^6.16.0",
    "pdfkit": "^0.15.0",
    "pg": "^8.11.3",
    "pg-hstore": "^2.3.4",
    "square": "^43.2.1",
    "uuid": "^9.0.1",
    "validator": "^13.15.26",
    "winston": "^3.11.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
