# ═══════════════════════════════════════════════════════════════════
# Light Engine Foxtrot — Cloud SaaS Environment Configuration
# ═══════════════════════════════════════════════════════════════════
# Copy to .env and fill in values before deploying.
# For EB deployment, set these via .ebextensions/nodecommand.config
# or the EB console → Configuration → Software → Environment properties.
# ═══════════════════════════════════════════════════════════════════

# ── Deployment Mode ──────────────────────────────────────────────
DEPLOYMENT_MODE=cloud
NODE_ENV=production

# ── Server ───────────────────────────────────────────────────────
PORT=8080                   # EB nginx proxy listens on 80, forwards to this port
WS_PORT=8081                # WebSocket server (EB ALB handles sticky sessions)

# ── Database (RDS PostgreSQL) ────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/greenreach_central
DB_SSL=true                 # Required for RDS
# Or individual vars (DATABASE_URL takes precedence):
# DB_HOST=light-engine-db.XXXXXXXX.us-east-1.rds.amazonaws.com
# DB_PORT=5432
# DB_NAME=greenreach_central
# DB_USER=greenreach_admin
# DB_PASSWORD=<from-secrets-manager>

# ── Authentication ───────────────────────────────────────────────
JWT_SECRET=<generate-with: openssl rand -base64 64>
ADMIN_TOKEN=<generate-with: openssl rand -hex 32>

# ── Domain & Routing ────────────────────────────────────────────
# Wildcard DNS: *.greenreachgreens.com → EB ALB
# App resolves subdomain → farm_id at the application layer
# No env var needed — server.js _extractSlug() reads Host header
# DOMAIN=greenreachgreens.com  # Optional: for logging/email templates

# ── Feature Flags (Cloud Mode) ──────────────────────────────────
ENABLE_DEVICE_CONTROL=false    # No direct hardware control from cloud
ENABLE_NUTRIENT_CONTROL=false  # Dosing requires local edge device
ENABLE_GRANT_WIZARD=true       # AI grant wizard available
# DEMO_MODE=false              # Not needed in multi-tenant cloud

# ── AWS Services ────────────────────────────────────────────────
AWS_REGION=us-east-1
# S3_DATA_BUCKET=light-engine-prod-data      # Per-tenant file uploads
# S3_BACKUPS_BUCKET=light-engine-prod-backups

# ── Email (AWS SES) ─────────────────────────────────────────────
# SES_FROM_EMAIL=noreply@greenreachgreens.com
# SES_REGION=us-east-1

# ── Monitoring ──────────────────────────────────────────────────
# SENTRY_DSN=https://...@sentry.io/...
# LOG_LEVEL=info

# ── Edge Device Sync ────────────────────────────────────────────
# Cloud server pulls data from edge devices (sensors, light schedules)
FARM_SYNC_INTERVAL_MS=300000   # 5 minutes
# FARM_EDGE_URL=                # Not needed — per-farm api_url from DB
FARM_DAILY_SYNC_HOUR=2         # 2 AM daily full sync
