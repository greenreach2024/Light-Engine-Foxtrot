# Phase 5: Wildcard subdomain routing for Cloud SaaS
# *.greenreachgreens.com → this EB environment
#
# Prerequisites (manual, one-time):
#   1. Route 53: A record *.greenreachgreens.com → EB ALB (Alias)
#   2. ACM: Wildcard cert for *.greenreachgreens.com (validated via DNS)
#   3. Update https-listener.config SSLCertificateArns with the wildcard cert ARN
#
# The server.js subdomain middleware (_extractSlug + _resolveSlug) handles:
#   notable-sprout.greenreachgreens.com → farms.slug='notable-sprout' → farm_id
#
# No ALB listener rules needed — all subdomains route to the same target group.
# Farm resolution happens at the application layer via the Host header.

option_settings:
  # Increase proxy timeout for long-polling / WebSocket upgrade
  aws:elasticbeanstalk:environment:proxy:
    ProxyServer: nginx
  
  # Sticky sessions for WebSocket connections
  aws:elasticbeanstalk:environment:process:default:
    StickinessEnabled: true
    StickinessLBCookieDuration: 86400
