option_settings:
  # Environment type - LoadBalanced for HTTPS support
  aws:elasticbeanstalk:environment:
    EnvironmentType: LoadBalanced
    LoadBalancerType: application
    ServiceRole: aws-elasticbeanstalk-service-role
  
  # HTTPS listener on port 443
  aws:elbv2:listener:443:
    Protocol: HTTPS
    SSLCertificateArns: arn:aws:acm:us-east-1:634419072974:certificate/adfc4d01-f688-45a2-a313-24cb4601f8e1
    SSLPolicy: ELBSecurityPolicy-TLS13-1-2-2021-06
    ListenerEnabled: true
    DefaultProcess: default
  
  # HTTP listener on port 80 (can redirect to HTTPS later)
  aws:elbv2:listener:default:
    ListenerEnabled: true
    Protocol: HTTP
  
  # Process settings
  aws:elasticbeanstalk:environment:process:default:
    HealthCheckPath: /health
    Port: '8080'
    Protocol: HTTP
