# GreenReach Central API - Environment Configuration

# Server Configuration
PORT=3000
NODE_ENV=development
API_VERSION=v1

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=greenreach_central
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_SSL=false

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRY=24h
REFRESH_TOKEN_EXPIRY=7d

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8091,https://dashboard.greenreach.io

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# WebSocket Configuration
WS_PORT=3001
WS_HEARTBEAT_INTERVAL=30000

# AWS Configuration (for production deployment)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Logging
LOG_LEVEL=info
LOG_FILE=logs/central-api.log

# Farm Registration
FARM_ID_PREFIX=GR
REGISTRATION_CODE_LENGTH=8
DEFAULT_FARM_TIER=starter

# Inventory Sync
SYNC_INTERVAL_MS=300000
MAX_SYNC_RETRIES=3

# Monitoring
HEALTH_CHECK_INTERVAL=30000
ALERT_EMAIL=ops@greenreachfarms.com

# External Services
STRIPE_SECRET_KEY=
SENDGRID_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
