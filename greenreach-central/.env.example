# GreenReach Central — Environment Variables Reference
# Copy to .env and fill in values.

# ── Core ──────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
BASE_URL=https://your-domain.com

# ── Authentication ────────────────────────────────────────
JWT_SECRET=                         # REQUIRED — ≥ 32 chars, e.g.: openssl rand -hex 32
WHOLESALE_JWT_SECRET=               # REQUIRED — separate secret for wholesale buyer JWTs
ADMIN_API_KEY=                      # API key for admin endpoints (X-API-Key header)
ADMIN_EMAIL=admin@example.com       # Default admin bootstrap credentials
ADMIN_PASSWORD=                     # Default admin bootstrap password
ADMIN_NAME=Admin

# ── Database (PostgreSQL) ─────────────────────────────────
DATABASE_URL=postgresql://user:pass@host:5432/greenreach_central  # REQUIRED
DB_SSL=true                         # Set false for localhost only
# Individual DB vars (alternative to DATABASE_URL):
# DB_HOST=  DB_PORT=5432  DB_NAME=  DB_USER=  DB_PASSWORD=

# ── Square Payments ───────────────────────────────────────
SQUARE_ACCESS_TOKEN=                # REQUIRED for checkout pipeline
SQUARE_LOCATION_ID=                 # REQUIRED for checkout pipeline
SQUARE_ENVIRONMENT=production       # sandbox | production
SQUARE_APP_ID=
SQUARE_APP_SECRET=
SQUARE_WEBHOOK_SECRET=

# ── Wholesale ─────────────────────────────────────────────
WHOLESALE_COMMISSION_RATE=0.15      # Default 15% broker fee
WHOLESALE_REQUIRE_DB_FOR_CRITICAL=true
WHOLESALE_CATALOG_MODE=live         # demo | live
# WHOLESALE_DELIVERY_ENABLED=true
# WHOLESALE_DELIVERY_BASE_FEE=15
# WHOLESALE_DELIVERY_MIN_ORDER=100
# WHOLESALE_ORDER_ARCHIVE_DAYS=90

# ── Procurement ───────────────────────────────────────────
PROCUREMENT_COMMISSION_RATE=0.10    # Default 10% procurement commission

# ── External Services (all optional) ─────────────────────
# OPENAI_API_KEY=                   # AI agent features
# GRANT_OPENAI_API_KEY=             # Grant wizard AI
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# SES_ENABLED=false
# SES_FROM_EMAIL=
# FOXTROT_API_URL=                  # Light Engine sync URL
