# LEAM Configuration
# Copy this to .env and fill in your farm credentials.
# LEAM reads this file on startup.

# GreenReach Central URL
CENTRAL_URL=https://greenreachgreens.com

# WebSocket port on Central
CENTRAL_WS_PORT=8443

# Farm authentication (use ONE of these methods):
# Option 1: JWT token (from farm login)
FARM_TOKEN=

# Option 2: API key + farm ID
# FARM_API_KEY=
# FARM_ID=

# Debug logging (true/false)
LEAM_VERBOSE=false
