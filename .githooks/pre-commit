#!/bin/bash
# Pre-commit hook: Framework compliance enforcement
# Authoritative playbook: .github/PLAYBOOK.md
# Location: .git/hooks/pre-commit (or via core.hooksPath = .githooks)
# Install: chmod +x .githooks/pre-commit && git config core.hooksPath .githooks

set -e

# ============================================================
# HARDENED ENVIRONMENT: Fail-closed PATH and dependency checks
# ============================================================
# Force a known PATH so hook behavior is deterministic regardless of
# the shell environment that invoked git commit.
export PATH="/usr/bin:/bin:/usr/sbin:/sbin:/usr/local/bin"

# Required external commands -- if any are missing, the hook BLOCKS.
REQUIRED_CMDS=(grep sed git)
for cmd in "${REQUIRED_CMDS[@]}"; do
  if ! command -v "$cmd" &>/dev/null; then
    echo ""
    echo "FRAMEWORK COMPLIANCE CHECK BLOCKED"
    echo "------------------------------------------------------------"
    echo "Required command not found: $cmd"
    echo "The pre-commit hook cannot run without it. Commit aborted."
    echo "------------------------------------------------------------"
    exit 1
  fi
done

RESET='\033[0m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'

echo ""
echo "FRAMEWORK COMPLIANCE CHECK (pre-commit hook)"
echo "------------------------------------------------------------"
echo ""

VIOLATIONS=0

# ============================================================
# RULE 1: Block direct modifications to canonical data files
# ============================================================
PROTECTED_FILES=(
  "public/data/farm.json"
  "public/data/groups.json"
  "public/data/rooms.json"
  "public/data/equipment.json"
  "public/data/ctrl-map.json"
)

CHANGED_FILES=$(git diff --cached --name-only 2>/dev/null || true)

for file in "${PROTECTED_FILES[@]}"; do
  if echo "$CHANGED_FILES" | grep -q "^$file$"; then
    echo -e "${RED}BLOCKED: Direct modification of canonical data file${RESET}"
    echo "   File: $file"
    echo "   Rule: DATA_FORMAT_STANDARDS.md - 'Do not modify canonical data files directly'"
    echo "   Solution: Use lib/data-adapters.js to normalize data instead"
    echo ""
    VIOLATIONS=$((VIOLATIONS + 1))
  fi
done

# ============================================================
# RULE 2: Block commits with demo data hardcoding
# ============================================================
DEMO_PATTERNS=(
  'light-engine-demo'
  'GR-00001'
  'DEMO-FARM-001'
  'FARM-001'
  'FARM-002'
  'FARM-003'
  'mockData'
  'fake.*data'
  'demo.*initialization'
)

DEMO_FOUND=0
for pattern in "${DEMO_PATTERNS[@]}"; do
  if git diff --cached -U0 | grep -E "$pattern" > /dev/null 2>&1; then
    if [ $DEMO_FOUND -eq 0 ]; then
      echo -e "${YELLOW}WARNING: Potential demo data found in staged changes${RESET}"
      echo ""
      DEMO_FOUND=1
    fi
    LINES=$(git diff --cached -U0 | grep -n "$pattern" | head -3)
    echo "   Pattern: $pattern"
    echo "$LINES" | sed 's/^/     /'
    echo ""
  fi
done

if [ $DEMO_FOUND -eq 1 ]; then
  read -p "Are you intentionally adding demo data? (type 'yes' to continue): " CONFIRM
  if [ "$CONFIRM" != "yes" ]; then
    echo -e "${RED}Commit aborted.${RESET}"
    exit 1
  fi
  echo ""
fi

# ============================================================
# RULE 3: Require schema validation for data file changes
# ============================================================
if echo "$CHANGED_FILES" | grep -q "public/data/"; then
  echo "  Checking data files changed - validating schemas..."
  if command -v npm &> /dev/null; then
    if ! npm run validate-schemas > /tmp/schema-validation.log 2>&1; then
      echo -e "${RED}BLOCKED: Schema validation failed${RESET}"
      echo "   Run: npm run validate-schemas"
      echo "   Error details:"
      cat /tmp/schema-validation.log | head -20
      echo ""
      VIOLATIONS=$((VIOLATIONS + 1))
    else
      echo -e "${GREEN}Schema validation passed${RESET}"
    fi
  else
    echo -e "${RED}BLOCKED: npm not found -- cannot validate schemas${RESET}"
    echo "   Schema validation is required for data file changes."
    echo "   Install Node.js/npm and retry."
    VIOLATIONS=$((VIOLATIONS + 1))
  fi
  echo ""
fi

# ============================================================
# RULE 4: Check farm.json for demo farm IDs
# ============================================================
if echo "$CHANGED_FILES" | grep -q "public/data/farm.json"; then
  echo "  Validating farm.json..."
  if command -v jq &> /dev/null; then
    FARM_ID=$(git show :public/data/farm.json 2>/dev/null | jq -r '.farmId' 2>/dev/null || echo "")
  else
    # Fallback: grep for farmId without jq
    FARM_ID=$(git show :public/data/farm.json 2>/dev/null | grep -oP '"farmId"\s*:\s*"\K[^"]+' 2>/dev/null || echo "")
  fi

  if [ -z "$FARM_ID" ] || [ "$FARM_ID" = "null" ]; then
    echo -e "${RED}BLOCKED: farm.json missing farmId${RESET}"
    VIOLATIONS=$((VIOLATIONS + 1))
  elif [ "$FARM_ID" = "light-engine-demo" ] || [ "$FARM_ID" = "DEMO-FARM-001" ]; then
    echo -e "${RED}BLOCKED: farm.json contains DEMO farm ID: $FARM_ID${RESET}"
    echo "   Update to production farm ID (e.g., FARM-MKLOMAT3-A9D8)"
    VIOLATIONS=$((VIOLATIONS + 1))
  else
    echo -e "${GREEN}farm.json farm ID valid: $FARM_ID${RESET}"
  fi
  echo ""
fi

# ============================================================
# RULE 5: Enforce commit message format (BLOCKING for code changes)
# ============================================================
COMMIT_MSG_FILE="${1:-}"
if [ -z "$COMMIT_MSG_FILE" ] || [ ! -f "$COMMIT_MSG_FILE" ]; then
  COMMIT_MSG_FILE=$(git rev-parse --git-dir)/COMMIT_EDITMSG
fi

if [ -f "$COMMIT_MSG_FILE" ]; then
  FIRST_LINE=$(head -1 "$COMMIT_MSG_FILE" 2>/dev/null || echo "")

  if [ -n "$FIRST_LINE" ]; then
    # Skip merge commits and WIP
    if ! echo "$FIRST_LINE" | grep -qE "^(Merge|WIP|merge)"; then

      # --------------------------------------------------------
      # 5a: Conventional format REQUIRED for code changes
      # --------------------------------------------------------
      if echo "$CHANGED_FILES" | grep -qE "\.(js|ts|json|html|css)$"; then
        if ! echo "$FIRST_LINE" | grep -qE "^(Fix|Feat|Docs|Refactor|Test|Framework|CRITICAL):"; then
          echo -e "${YELLOW}Commit message should use conventional format${RESET}"
          echo "   Format: Fix: | Feat: | Docs: | Refactor: | Test: | Framework: | CRITICAL:"
          echo "   Your message: $FIRST_LINE"
          echo ""
          # Warning only for format -- not a hard block (yet)
        fi
      fi

      # --------------------------------------------------------
      # 5b: Review notation REQUIRED (BLOCKING) for scoped code changes
      # --------------------------------------------------------
      if echo "$CHANGED_FILES" | grep -qE "^(lib/|server-foxtrot|public/data|greenreach-central/routes/|greenreach-central/server\.js)"; then
        if ! cat "$COMMIT_MSG_FILE" | grep -iqE "(Review Agent approved|Architecture Agent approved|multi-agent review)"; then
          echo -e "${RED}BLOCKED: Significant code change without review notation${RESET}"
          echo "   Files matched: $(echo "$CHANGED_FILES" | grep -E "^(lib/|server-foxtrot|public/data|greenreach-central/routes/|greenreach-central/server\.js)" | head -5)"
          echo "   Add to commit message: '(Review Agent approved)' or '(Architecture Agent approved)'"
          echo ""
          VIOLATIONS=$((VIOLATIONS + 1))
        fi
      fi

    fi
  fi
fi

# ============================================================
# RULE 6: Branch freshness check (WARNING)
# ============================================================
# Warn when the current branch is significantly behind origin/main.
# This is advisory -- it does not block commits.
if git rev-parse --verify origin/main &>/dev/null 2>&1; then
  BEHIND=$(git rev-list --count HEAD..origin/main 2>/dev/null || echo "0")
  if [ "$BEHIND" -gt 20 ]; then
    echo -e "${YELLOW}WARNING: Branch is ${BEHIND} commits behind origin/main${RESET}"
    echo "   Consider rebasing or merging from main before deploying."
    echo "   Run: git fetch origin && git merge origin/main"
    echo ""
  elif [ "$BEHIND" -gt 0 ]; then
    echo -e "${YELLOW}Note: Branch is ${BEHIND} commits behind origin/main${RESET}"
    echo ""
  fi
fi

# ============================================================
# RULE 7: Block deprecated EB references in staged code
# ============================================================
if git diff --cached -U0 -- '*.js' '*.md' '*.sh' '*.json' 2>/dev/null | grep -qE "(eb deploy|eb setenv|elasticbeanstalk|light-engine-foxtrot-prod-v[0-9]|greenreach-central-prod-v[0-9])"; then
  echo -e "${YELLOW}WARNING: Staged changes contain deprecated EB references${RESET}"
  echo "   The platform migrated to Google Cloud Run in April 2026."
  echo "   Remove all EB environment names, eb CLI commands, and aws elasticbeanstalk references."
  echo ""
fi

# ============================================================
# REPORT RESULTS
# ============================================================
echo "------------------------------------------------------------"

if [ $VIOLATIONS -gt 0 ]; then
  echo ""
  echo -e "${RED}FRAMEWORK COMPLIANCE CHECK FAILED ($VIOLATIONS violations)${RESET}"
  echo ""
  echo "Cannot proceed with commit. Fix violations above and try again."
  echo ""
  echo "Documentation:"
  echo "   - .github/PLAYBOOK.md (authoritative policy)"
  echo "   - .github/AGENT_SKILLS_FRAMEWORK.md"
  echo "   - .github/DATA_FORMAT_STANDARDS.md"
  echo ""
  exit 1
fi

echo ""
echo -e "${GREEN}Framework compliance check PASSED${RESET}"
echo ""
exit 0
