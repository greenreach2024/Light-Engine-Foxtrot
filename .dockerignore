# .dockerignore - Exclude files from Docker build context

# Git
.git
.gitignore
.gitattributes

# Node
node_modules
npm-debug.log
yarn-error.log

# Environment
.env
.env.*

# Documentation
*.md
docs/
examples/

# Tests
tests/
test/
*.test.js
*.spec.js

# Development
.vscode/
.idea/
*.swp
*.swo
*~

# Build artifacts
dist/
build/
.next/

# Logs
logs/
*.log

# OS
.DS_Store
Thumbs.db

# Backup files
*.bak
*.backup
backups/
data.aws-backup/
lib.aws-backup/
server.aws-backup/

# Desktop app (not needed in cloud)
desktop-app/

# AWS infrastructure (not needed in container)
aws-infrastructure/

# Central app (separate container)
greenreach-central-app/

# Edge-specific
edge-install-server/
firmware/
esp32/

# Tools
tools/
scripts/build-*.sh
scripts/publish-*.sh

# Data directories
data/
db/*.db
db/*.db-*

# Temporary
tmp/
temp/
*.tmp

# IDE
.project
.classpath
.settings/

# CI/CD
.github/
.travis.yml
.circleci/

# Migration scripts
alembic/
migrations/
