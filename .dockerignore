# LE .dockerignore - keep image small, mirror .ebignore logic
.git
.github
.vscode
.elasticbeanstalk
**/.elasticbeanstalk
node_modules
venv
.venv
__pycache__
*.pyc

# Archives and backups
archive/
backups/
data.aws-backup/
lib.aws-backup/
server.aws-backup/
tmp/

# Test and dev files
test/
tests/
aws-testing/
*.test.js
playwright.config.mjs

# Docs
docs/
examples/
*.md

# Large media
*.mov
*.mp4
*.avi
*.har
public/videos/
public/images/plant-farm/

# Build artifacts
*.zip
*.bundle.js
logs/
*.log
npm-debug.log*

# Environment files (secrets passed via Cloud Run env vars)
.env
.env.*
*.pem
*.key
*.crt

# Scripts not needed in container
*.sh
!scripts/simple-anomaly-detector.py

# Central code is NOT deployed with LE (separate service)
# But LE serves greenreach-central/public/ as static files,
# so we include that dir and exclude the rest.
greenreach-central/node_modules/
greenreach-central/routes/
greenreach-central/services/
!greenreach-central/services/notification-store.js
greenreach-central/lib/
greenreach-central/middleware/
greenreach-central/config/
!greenreach-central/config/database.js
greenreach-central/data/
greenreach-central/docs/
greenreach-central/scripts/
greenreach-central/backups/
greenreach-central/tests/
greenreach-central/migrations/
greenreach-central/reports/
greenreach-central/logs/
greenreach-central/server.js
greenreach-central/server.js.*
greenreach-central/Dockerfile
greenreach-central/.dockerignore
greenreach-central/.env*
greenreach-central/package*.json
greenreach-central/*.md
greenreach-central/*.txt
greenreach-central/*.mjs
greenreach-central/*.bak
greenreach-central/public/videos/

# Other unneeded dirs
light-engine-access-manager/
greenreach-central-app/
external/
config/sync-queue.json
data/sync-monitor-snapshot.json

# OS files
.DS_Store
Thumbs.db

# Dockerfile itself
Dockerfile

# Per-farm demo/state JSONs -- MUST NOT ship in LE image.
# farmStore reads DB → in-memory → DEFAULTS only (flat-file fallback removed in
# a2cd5454). These files shipped in the image previously leaked 78 demo groups
# and stale room dims to unauthenticated /data/*.json callers.
# groups.json and rooms.json intentionally ship (empty stubs) --
# required by LE framework validator at startup. farmStore read-fallback
# is disabled (a2cd5454) so empty stubs cannot leak state.
public/data/room-map.json
public/data/farm.json
public/data/farm-settings.json
public/data/iot-devices.json
public/data/env.json
public/data/env-cache.json
public/data/plans.json
public/data/inventory.json
public/data/schedules.json
public/data/configuration.json
public/data/dedicated-crops.json
public/data/procurement-orders.json
public/data/nutrient-dashboard.json
public/data/demo-farm-data.json
public/data/planting-schedule.json
public/data/harvest-log.json
public/data/system-alerts.json
public/data/ai-recommendations.json
public/data/devices.cache.json
public/data/wholesale-orders-status.json
public/data/wholesale-order-events.json
public/data/wholesale-reservations.json
public/data/demand-succession-suggestions.json
