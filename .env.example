# ─── Server ───────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# ─── Database ─────────────────────────────────────────
DATABASE_URL=postgres://foxtrot:foxtrot@localhost:5432/light_engine_foxtrot
DB_POOL_MIN=2
DB_POOL_MAX=10

# ─── Auth (JWT) ───────────────────────────────────────
JWT_SECRET=change-me-in-production-use-openssl-rand-64
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=30d

# ─── Routing Engine ──────────────────────────────────
# Max stops per route
ROUTE_MAX_STOPS=18
# Max active minutes per route
ROUTE_MAX_DURATION_MIN=270
# Cold-chain max minutes from pickup to last drop
COLD_CHAIN_MAX_MIN=180

# ─── Pricing Defaults ────────────────────────────────
# Route operating cost rates
COST_PER_KM=0.35
COST_PER_MIN=0.10
COST_PER_STOP=0.60
COST_PER_WAIT_MIN=0.08

# Cost allocation weights (must sum to 1.0)
ALLOC_W_KM=0.45
ALLOC_W_MIN=0.35
ALLOC_W_VOL=0.15
ALLOC_W_EQUAL=0.05

# Margin applied on top of allocated cost
DEFAULT_MARGIN=0.55

# ─── Driver Pay Defaults ─────────────────────────────
PAY_BASE=15.00
PAY_PER_KM=0.55
PAY_PER_ACTIVE_MIN=0.18
PAY_PER_STOP=1.25
PAY_PER_WAIT_MIN=0.20
# Minimum earnings rate $/min (floor guarantee)
MIN_EARNINGS_RATE_PER_MIN=0.35
# Wait grace period before paid wait starts (minutes)
WAIT_GRACE_MIN=10

# ─── Depot / Farm Origin ─────────────────────────────
# Latitude and longitude of the depot (farm departure point)
DEPOT_LAT=36.6777
DEPOT_LNG=-121.6555

# ─── Tax ──────────────────────────────────────────────
# Tax rate for billing invoices (0.13 = 13% HST)
TAX_RATE=0.13

# ─── Stripe (Phase 2 — Driver Payouts) ───────────────
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder

# ─── S3 / Object Storage (Phase 2 — Documents) ──────
S3_BUCKET=lef-dev-uploads
S3_REGION=us-east-1

# ─── Notifications ───────────────────────────────────
# SMTP / SendGrid / Twilio keys go here
# SMTP_HOST=
# SMTP_PORT=
# TWILIO_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM=
