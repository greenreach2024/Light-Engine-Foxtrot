# Light Engine Foxtrot - Environment Variables

# ============================================================================
# PYTHON ENVIRONMENT (REQUIRED FOR ML/AI FEATURES)
# ============================================================================
# Path to Python binary with ML dependencies installed
# Use virtual environment Python for isolation (recommended)
# 
# Setup instructions:
#   1. Create virtual environment: python3 -m venv venv
#   2. Activate: source venv/bin/activate
#   3. Install: pip install -r requirements.txt
#   4. Set path below to: /full/path/to/Light-Engine-Foxtrot/venv/bin/python3
#
PYTHON_BIN=/Users/YOUR_USERNAME/Light-Engine-Foxtrot/venv/bin/python3

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================
PORT=8091
HOST=127.0.0.1

# ============================================================================
# DATABASE CONFIGURATION (TASK #3 - PRODUCTION PERSISTENCE)
# ============================================================================
# Enable PostgreSQL for production (set to true) or use NeDB for dev/demo (false)
DB_ENABLED=false
DB_HOST=localhost
DB_PORT=5432
DB_NAME=light_engine
DB_USER=postgres
DB_PASSWORD=
DB_POOL_MAX=20
DB_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=2000

# ============================================================================
# DEMO MODE CONFIGURATION
# ============================================================================
# Enable demo mode with synthetic farm data (RECOMMENDED FOR DEMOS/TESTING)
# When enabled, serves realistic demo data instead of requiring real devices
DEMO_MODE=false

# Demo farm identifier (must match data/demo/demo-farm-complete.json)
DEMO_FARM_ID=DEMO-FARM-001

# Enable real-time sensor data simulation (updates every 60 seconds)
DEMO_REALTIME=false

# Persist demo data to database (for RDS testing scenarios)
DEMO_PERSIST=false

# ============================================================================
# SECURITY CONFIGURATION (PRODUCTION)
# ============================================================================
# Authentication & Authorization
AUTH_ENABLED=false  # Set to true for production
JWT_SECRET=your-secret-key-here-change-in-production  # MUST CHANGE: Generate with: openssl rand -base64 64
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# IMPORTANT: For AWS deployments, store JWT_SECRET in AWS Secrets Manager
# and reference it in Elastic Beanstalk configuration instead of .env file
# Example: arn:aws:secretsmanager:us-east-1:123456789:secret:foxtrot/jwt-secret

# Rate Limiting (Protection against abuse and DDoS)
RATE_LIMITING_ENABLED=false  # Set to true for production
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes (in milliseconds)
RATE_LIMIT_MAX_REQUESTS=100  # Max requests per window
RATE_LIMIT_AUTH_MAX=5  # Stricter limit for auth endpoints
RATE_LIMIT_WRITE_MAX=30  # Stricter limit for write operations

# Redis for distributed rate limiting (optional, recommended for multi-instance)
# If not configured, uses in-memory store (single instance only)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Audit Logging
AUDIT_LOG_ENABLED=true  # Set to false to disable audit logging
AUDIT_LOG_FILE=logs/audit.log  # Local audit log file
AUDIT_LOG_CLOUDWATCH=true  # Send audit logs to CloudWatch (AWS only)

# CloudWatch Metrics (Task #11 - Production Monitoring)
CLOUDWATCH_ENABLED=false  # Set to true for production
CLOUDWATCH_NAMESPACE=LightEngine/Foxtrot  # Custom metrics namespace
CLOUDWATCH_REGION=us-east-1  # AWS region
CLOUDWATCH_PUBLISH_INTERVAL=60000  # Publish interval in ms (default: 1 minute)

# AWS Credentials (required when CloudWatch is enabled)
# For production, use IAM roles instead of access keys
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# CORS (Cross-Origin Resource Sharing)
# Allowed origins are configured in server/middleware/cors.js
# Update ALLOWED_ORIGINS array for production domains

# ============================================================================
# SQUARE PAYMENT INTEGRATION
# ============================================================================
# Sandbox credentials (for testing)
SQUARE_ENVIRONMENT=sandbox
SQUARE_APPLICATION_ID=sandbox-sq0idb-ByoyD4t2Zy96QhAUZd9_SA
SQUARE_LOCATION_ID=TC4Z3ZEBKRXRH
SQUARE_ACCESS_TOKEN=EAAAl3UxQY8RcG0UonmzQVkQHDUNVeivA6FPDDWRMskq0F2j1_WieB9SSowKUifa
SQUARE_WEBHOOK_SIGNATURE_KEY=

# Production credentials (uncomment and set for production)
# SQUARE_ENVIRONMENT=production
# SQUARE_APPLICATION_ID=your-production-app-id
# SQUARE_LOCATION_ID=your-production-location-id
# SQUARE_ACCESS_TOKEN=your-production-access-token
# SQUARE_WEBHOOK_SIGNATURE_KEY=your-webhook-signature-key

# ============================================================================
# SWITCHBOT INTEGRATION
# ============================================================================
SWITCHBOT_TOKEN=
SWITCHBOT_SECRET=

# ============================================================================
# MQTT BROKER
# ============================================================================
MQTT_HOST=192.168.2.38
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TOPICS=sensors/#

# ============================================================================
# ENVIRONMENTAL DATA SOURCE
# ============================================================================
ENV_SOURCE=local  # Options: local, cloud
CLOUD_ENDPOINT_URL=
AWS_ENDPOINT_URL=

# ============================================================================
# DEVICE DISCOVERY
# ============================================================================
KASA_DISCOVERY_TIMEOUT=10
DISCOVERY_INTERVAL=300

# ============================================================================
# AUTOMATION RULES
# ============================================================================
TARGET_LUX=800
OCCUPIED_BRIGHTNESS=100
VACANT_BRIGHTNESS=30

# ============================================================================
# MOBILE NOTIFICATIONS (WHOLESALE ORDERS)
# ============================================================================
# SMS Notifications via Twilio (ONE account for all farms)
# Sign up at: https://www.twilio.com (free $15 credit for testing)
# Cost: ~$0.008/SMS (< 1¢), $1/month for phone number
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+16135551234

# Push Notifications via Firebase Cloud Messaging (ONE project for all farms)
# Setup guide at: https://console.firebase.google.com
# Cost: FREE (unlimited push notifications)
# Steps:
#   1. Create Firebase project
#   2. Enable Cloud Messaging
#   3. Create service account: Settings > Service Accounts > Generate Private Key
#   4. Download JSON file and specify path below
FIREBASE_SERVICE_ACCOUNT_PATH=/path/to/greenreach-firebase-service-account.json

# Notification preferences (optional overrides)
NOTIFICATIONS_QUIET_HOURS_START=22:00  # Default quiet hours start (10 PM)
NOTIFICATIONS_QUIET_HOURS_END=08:00    # Default quiet hours end (8 AM)
NOTIFICATIONS_TIMEZONE=America/Toronto  # Default timezone for quiet hours

# ============================================================================
# DATABASE (Future - PostgreSQL migration)
# ============================================================================
# DATABASE_URL=postgresql://user:password@localhost:5432/light_engine
# DATABASE_POOL_SIZE=10
# DATABASE_MAX_OVERFLOW=20
