# ============================================================================
# Python Backend Environment Configuration
# ============================================================================
# This file configures the FastAPI backend server (backend/server.py)
# Copy to .env.python and fill in your values
#
# NEVER commit .env.python to version control!
# Add to .gitignore: .env.python
# ============================================================================

# ----------------------------------------------------------------------------
# Server Configuration
# ----------------------------------------------------------------------------
# FastAPI server settings
ENVIRONMENT=production  # Options: development, production
HOST=0.0.0.0           # Bind address (0.0.0.0 for all interfaces)
PORT=8000              # Python backend port

# ----------------------------------------------------------------------------
# Authentication & Security
# ----------------------------------------------------------------------------
# JWT authentication settings
AUTH_ENABLED=false      # Set to true for production
JWT_SECRET=change-this-secret-key-in-production-use-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:8091,http://127.0.0.1:8091

# ----------------------------------------------------------------------------
# Rate Limiting
# ----------------------------------------------------------------------------
# API rate limiting (requires Redis)
RATE_LIMITING_ENABLED=false  # Set to true to enable
REDIS_HOST=localhost
REDIS_PORT=6379

# ----------------------------------------------------------------------------
# Database Configuration
# ----------------------------------------------------------------------------
# PostgreSQL connection string (for inventory system)
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://light_engine:password@localhost:5432/light_engine

# SQLite fallback (for development)
# DATABASE_URL=sqlite:///./light_engine.db

# Database pool settings
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# ----------------------------------------------------------------------------
# Square Payment Integration
# ----------------------------------------------------------------------------
# Sandbox credentials (for testing)
SQUARE_ENVIRONMENT=sandbox
SQUARE_ACCESS_TOKEN=EAAAl3UxQY8RcG0UonmzQVkQHDUNVeivA6FPDDWRMskq0F2j1_WieB9SSowKUifa
SQUARE_APPLICATION_ID=sandbox-sq0idb-ByoyD4t2Zy96QhAUZd9_SA
SQUARE_LOCATION_ID=TC4Z3ZEBKRXRH
SQUARE_WEBHOOK_SIGNATURE_KEY=

# Production credentials (uncomment and set for production)
# SQUARE_ENVIRONMENT=production
# SQUARE_ACCESS_TOKEN=your-production-access-token
# SQUARE_APPLICATION_ID=your-production-app-id
# SQUARE_LOCATION_ID=your-production-location-id
# SQUARE_WEBHOOK_SIGNATURE_KEY=your-webhook-signature-key

# ----------------------------------------------------------------------------
# AWS Integration
# ----------------------------------------------------------------------------
# AWS credentials (for S3 and CloudWatch)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# S3 configuration
AWS_S3_BUCKET=light-engine-data
AWS_S3_PREFIX=production/  # Optional prefix for all keys

# CloudWatch configuration
AWS_CLOUDWATCH_LOG_GROUP=/light-engine/production
AWS_CLOUDWATCH_NAMESPACE=LightEngine

# Enable/disable AWS features
AWS_S3_ENABLED=false
AWS_CLOUDWATCH_ENABLED=false

# ----------------------------------------------------------------------------
# Device Discovery & Control
# ----------------------------------------------------------------------------
# TP-Link Kasa device discovery
KASA_DISCOVERY_TIMEOUT=10  # Seconds
KASA_DISCOVERY_INTERVAL=300  # 5 minutes

# MQTT broker settings
MQTT_HOST=192.168.2.38
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TOPICS=sensors/#,lights/#

# SwitchBot Cloud API (for device discovery)
SWITCHBOT_TOKEN=
SWITCHBOT_SECRET=

# BLE device discovery
BLE_SCAN_DURATION=10  # Seconds

# mDNS/Bonjour discovery
MDNS_TIMEOUT=5  # Seconds

# ----------------------------------------------------------------------------
# Automation Engine
# ----------------------------------------------------------------------------
# Lighting automation settings
TARGET_LUX=800                    # Target light level for balancing
OCCUPIED_BRIGHTNESS=100           # Brightness when room occupied (%)
VACANT_BRIGHTNESS=30              # Brightness when room vacant (%)
FAILSAFE_POWER_LIMIT=5000         # Maximum power consumption (W)

# Discovery supervisor interval
DISCOVERY_INTERVAL=300            # Auto-discovery interval (seconds)

# ----------------------------------------------------------------------------
# Logging Configuration
# ----------------------------------------------------------------------------
# Python logging level
LOG_LEVEL=INFO  # Options: DEBUG, INFO, WARNING, ERROR, CRITICAL

# Log file location (optional)
LOG_FILE=/var/log/light-engine/backend.log

# Enable structured logging (JSON format)
STRUCTURED_LOGGING=false

# ----------------------------------------------------------------------------
# Development Settings
# ----------------------------------------------------------------------------
# Enable debug mode (detailed error messages, auto-reload)
DEBUG=false

# Enable API documentation endpoints (/docs, /redoc)
ENABLE_DOCS=true

# Enable test/development endpoints
ENABLE_TEST_ENDPOINTS=false

# ----------------------------------------------------------------------------
# Inventory System
# ----------------------------------------------------------------------------
# Default tray format (if not specified)
DEFAULT_TRAY_FORMAT=10x20

# Forecast calculation intervals
HARVEST_FORECAST_DAYS=30

# Alert thresholds
LOW_INVENTORY_THRESHOLD=10  # Alert when plant count drops below

# ----------------------------------------------------------------------------
# Monitoring & Metrics
# ----------------------------------------------------------------------------
# Health check interval
HEALTH_CHECK_INTERVAL=60  # Seconds

# Metrics collection
ENABLE_METRICS=true
METRICS_PORT=9090  # Prometheus metrics endpoint

# Performance monitoring
SLOW_QUERY_THRESHOLD=1.0  # Log queries slower than 1 second
SLOW_REQUEST_THRESHOLD=2.0  # Log requests slower than 2 seconds

# ----------------------------------------------------------------------------
# Email Notifications (AWS SES)
# ----------------------------------------------------------------------------
# AWS SES configuration
SES_FROM_EMAIL=noreply@light-engine.com
SES_FROM_NAME=Light Engine Alerts
SES_REGION=us-east-1

# Alert email recipients (comma-separated)
ALERT_EMAIL_RECIPIENTS=admin@example.com,ops@example.com

# Enable email notifications
EMAIL_ALERTS_ENABLED=false

# ----------------------------------------------------------------------------
# Backup & Maintenance
# ----------------------------------------------------------------------------
# Database backup schedule (cron format)
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM

# Backup retention (days)
BACKUP_RETENTION_DAYS=30

# S3 bucket for backups
BACKUP_S3_BUCKET=light-engine-backups

# ----------------------------------------------------------------------------
# Feature Flags
# ----------------------------------------------------------------------------
# Enable/disable features
FEATURE_INVENTORY_ENABLED=true
FEATURE_BILLING_ENABLED=false  # Enable when Square configured
FEATURE_AWS_INTEGRATION=false  # Enable when AWS configured
FEATURE_ML_FORECASTING=false   # Enable when ML models deployed
FEATURE_AUTOMATION_RULES=true

# ----------------------------------------------------------------------------
# External API Integrations
# ----------------------------------------------------------------------------
# Weather API (for environmental data)
WEATHER_API_KEY=
WEATHER_API_URL=https://api.openweathermap.org/data/2.5/weather

# IFTTT webhook integration
IFTTT_WEBHOOK_KEY=

# Custom webhook URLs
ALERT_WEBHOOK_URL=
STATUS_WEBHOOK_URL=

# ----------------------------------------------------------------------------
# Security Headers
# ----------------------------------------------------------------------------
# HSTS (HTTP Strict Transport Security)
HSTS_MAX_AGE=31536000  # 1 year

# Content Security Policy
CSP_POLICY=default-src 'self'

# ----------------------------------------------------------------------------
# Notes
# ----------------------------------------------------------------------------
# 1. Required variables for basic operation:
#    - DATABASE_URL (or use SQLite for dev)
#    - JWT_SECRET (change default)
#
# 2. Required for Square billing:
#    - SQUARE_ACCESS_TOKEN
#    - SQUARE_LOCATION_ID
#
# 3. Required for AWS features:
#    - AWS_ACCESS_KEY_ID
#    - AWS_SECRET_ACCESS_KEY
#    - AWS_S3_BUCKET (for S3)
#    - AWS_CLOUDWATCH_LOG_GROUP (for CloudWatch)
#
# 4. For production deployment:
#    - Set AUTH_ENABLED=true
#    - Set RATE_LIMITING_ENABLED=true
#    - Change all default secrets/passwords
#    - Enable HTTPS/TLS
#    - Configure proper CORS_ORIGINS
#    - Set up database backups
#    - Configure monitoring alerts
