option_settings:
  # Application Environment
  aws:elasticbeanstalk:application:environment:
    PORT: "8091"
    NODE_ENV: "production"
    
    # Database Configuration (Set by deployment script)
    DB_ENABLED: "true"
    # DB_HOST: set by deploy script
    # DB_PORT: "5432"
    # DB_NAME: set by deploy script
    # DB_USER: set by deploy script
    
    # Security
    RATE_LIMITING_ENABLED: "true"
    AUDIT_LOG_ENABLED: "true"
    
    # CloudWatch Monitoring
    CLOUDWATCH_ENABLED: "true"
    CLOUDWATCH_NAMESPACE: "LightEngine/Foxtrot"
    # CLOUDWATCH_REGION: set by deploy script
    CLOUDWATCH_PUBLISH_INTERVAL: "60000"
    
    # Demo Mode (disable in production)
    DEMO_MODE: "false"
  
  # Nginx Proxy Configuration
  aws:elasticbeanstalk:environment:proxy:
    ProxyServer: nginx
  
  # Static Files
  aws:elasticbeanstalk:environment:proxy:staticfiles:
    /public: public
  
  # Instance Configuration
  aws:autoscaling:launchconfiguration:
    InstanceType: t3.small
    RootVolumeType: gp3
    RootVolumeSize: 20
  
  # Auto Scaling
  aws:autoscaling:asg:
    MinSize: 1
    MaxSize: 4
  
  # Load Balancer Health Check
  aws:elasticbeanstalk:environment:process:default:
    HealthCheckPath: /health
    HealthCheckInterval: 30
    HealthCheckTimeout: 5
    UnhealthyThresholdCount: 3
    HealthyThresholdCount: 2
  
  # CloudWatch Logs
  aws:elasticbeanstalk:cloudwatch:logs:
    StreamLogs: true
    DeleteOnTerminate: false
    RetentionInDays: 7

files:
  # Retrieve secrets from AWS Secrets Manager on startup
  "/opt/elasticbeanstalk/hooks/appdeploy/pre/01_get_secrets.sh":
    mode: "000755"
    owner: root
    group: root
    content: |
      #!/bin/bash
      set -e
      
      echo "Retrieving secrets from AWS Secrets Manager..."
      
      # Get region from instance metadata
      REGION=$(curl -s http://169.254.169.254/latest/meta-data/placement/region)
      
      # Retrieve JWT secret
      JWT_SECRET=$(aws secretsmanager get-secret-value \
        --secret-id foxtrot/jwt-secret \
        --region $REGION \
        --query SecretString \
        --output text)
      
      # Retrieve DB password
      DB_PASSWORD=$(aws secretsmanager get-secret-value \
        --secret-id foxtrot/db-password \
        --region $REGION \
        --query SecretString \
        --output text)
      
      # Export to environment file for Node.js
      echo "JWT_SECRET=$JWT_SECRET" >> /opt/elasticbeanstalk/deployment/env
      echo "DB_PASSWORD=$DB_PASSWORD" >> /opt/elasticbeanstalk/deployment/env
      
      # Retrieve Square API keys if they exist
      if aws secretsmanager describe-secret --secret-id foxtrot/square-access-token --region $REGION 2>/dev/null; then
        SQUARE_ACCESS_TOKEN=$(aws secretsmanager get-secret-value \
          --secret-id foxtrot/square-access-token \
          --region $REGION \
          --query SecretString \
          --output text)
        echo "SQUARE_ACCESS_TOKEN=$SQUARE_ACCESS_TOKEN" >> /opt/elasticbeanstalk/deployment/env
      fi
      
      if aws secretsmanager describe-secret --secret-id foxtrot/square-location-id --region $REGION 2>/dev/null; then
        SQUARE_LOCATION_ID=$(aws secretsmanager get-secret-value \
          --secret-id foxtrot/square-location-id \
          --region $REGION \
          --query SecretString \
          --output text)
        echo "SQUARE_LOCATION_ID=$SQUARE_LOCATION_ID" >> /opt/elasticbeanstalk/deployment/env
      fi
      
      echo "✓ Secrets retrieved successfully"
  
  # Ensure data directories exist with correct permissions
  "/opt/elasticbeanstalk/hooks/appdeploy/post/99_setup_directories.sh":
    mode: "000755"
    owner: root
    group: root
    content: |
      #!/bin/bash
      set -e
      
      echo "Setting up data directories..."
      
      # Create necessary directories
      mkdir -p /var/app/current/data
      mkdir -p /var/app/current/logs
      mkdir -p /var/app/current/backups
      
      # Set ownership
      chown -R webapp:webapp /var/app/current/data
      chown -R webapp:webapp /var/app/current/logs
      chown -R webapp:webapp /var/app/current/backups
      
      # Set permissions
      chmod 755 /var/app/current/data
      chmod 755 /var/app/current/logs
      chmod 755 /var/app/current/backups
      
      echo "✓ Directories created successfully"
  
  # Install production dependencies
  "/opt/elasticbeanstalk/hooks/appdeploy/pre/50_npm_install.sh":
    mode: "000755"
    owner: root
    group: root
    content: |
      #!/bin/bash
      set -e
      
      echo "Installing production dependencies..."
      cd /var/app/staging
      
      # Clean install with production only
      npm ci --production
      
      echo "✓ Dependencies installed successfully"

packages:
  yum:
    postgresql15: []
    
commands:
  01_node_install:
    command: |
      # Ensure Node.js 20 is available
      curl -fsSL https://rpm.nodesource.com/setup_20.x | bash -
      yum install -y nodejs
    ignoreErrors: false
