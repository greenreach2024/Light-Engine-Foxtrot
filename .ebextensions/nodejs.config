option_settings:
  aws:elasticbeanstalk:application:environment:
    PORT: "8080"
    NODE_ENV: "production"
    DEMO_MODE: "true"
    DEMO_FARM_ID: "DEMO-FARM-001"
    DEMO_REALTIME: "true"
  aws:elasticbeanstalk:environment:proxy:
    ProxyServer: nginx
  aws:elasticbeanstalk:environment:proxy:staticfiles:
    /public: public

files:
  "/opt/elasticbeanstalk/hooks/appdeploy/post/99_copy_demo_data.sh":
    mode: "000755"
    owner: root
    group: root
    content: |
      #!/bin/bash
      # Ensure demo data directory exists and has correct permissions
      mkdir -p /var/app/current/data/demo
      chown -R webapp:webapp /var/app/current/data
      
      # Copy demo data if it exists in the deployment
      if [ -f /var/app/current/data/demo/demo-farm-complete.json ]; then
        echo "Demo farm data found at /var/app/current/data/demo/demo-farm-complete.json"
      else
        echo "WARNING: Demo farm data not found!"
      fi
