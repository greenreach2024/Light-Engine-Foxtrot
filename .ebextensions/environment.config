option_settings:
  aws:elasticbeanstalk:application:environment:
    # Square Payment Configuration
    SQUARE_ENVIRONMENT: sandbox
    SQUARE_APPLICATION_ID: sandbox-sq0idb-ByoyD4t2Zy96QhAUZd9_SA
    SQUARE_LOCATION_ID: TC4Z3ZEBKRXRH
    SQUARE_ACCESS_TOKEN: EAAAl3UxQY8RcG0UonmzQVkQHDUNVeivA6FPDDWRMskq0F2j1_WieB9SSowKUifa
    
    # Email Service Configuration
    EMAIL_PROVIDER: ses
    EMAIL_FROM: noreply@lightengine.farm
    EMAIL_FROM_NAME: Light Engine Foxtrot
    AWS_REGION: us-east-1
  
  # Configure health check to use /healthz endpoint (simpler, no DB check)
  aws:elasticbeanstalk:environment:process:default:
    HealthCheckPath: /healthz
    HealthCheckInterval: 15
    HealthCheckTimeout: 5
    HealthyThresholdCount: 3
    UnhealthyThresholdCount: 5
